{
  "name": "signalk-nmea2000-emitter-cannon",
  "version": "1.0.1",
  "description": "Signal K server plugin to convert Signal K to NMEA2000 with Garmin PGN specification alignment and canboatjs framework compatibility",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist/",
    "assets/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run clean && esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --external:@canboat/canboatjs --external:rxjs --external:es-toolkit --external:path-scurry",
    "build:npm": "npm run build",
    "build:watch": "npm run build -- --watch",
    "dev": "tsx src/index.ts",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "biome lint src/",
    "format": "biome format src/ --write",
    "check": "biome check src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepack": "npm run build",
    "create-release": "github-create-release --owner NearlCrews --repository signalk-nmea2000-emitter-cannon",
    "release": "git tag -d v$npm_package_version ; git tag v$npm_package_version && git push --tags && git push && npm run create-release"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-nmea2000",
    "signalk-category-navigation",
    "nmea2000",
    "garmin",
    "marine-electronics",
    "ais",
    "navigation"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "appIcon": "./assets/icons/icon-72x72.png",
    "displayName": "Signal K NMEA2000 Emitter Cannon"
  },
  "author": {
    "name": "Scott Bender",
    "email": "scott@scottbender.net"
  },
  "contributors": [
    {
      "name": "Teppo Kurki"
    },
    {
      "name": "NearlCrews",
      "url": "https://github.com/NearlCrews"
    }
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "es-toolkit": "^1.40.0",
    "path-scurry": "^2.0.0",
    "rxjs": "^7.8.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NearlCrews/signalk-nmea2000-emitter-cannon.git"
  },
  "homepage": "https://github.com/NearlCrews/signalk-nmea2000-emitter-cannon#readme",
  "bugs": {
    "url": "https://github.com/NearlCrews/signalk-nmea2000-emitter-cannon/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@canboat/canboatjs": "^3.11.0",
    "@types/node": "^24.7.2",
    "@vitest/ui": "^3.2.4",
    "esbuild": "^0.25.10",
    "sharp": "^0.34.4",
    "signalk-server": "^2.16.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "nanoid": "^3.3.8",
    "semver": "^7.6.3",
    "tmp": "^0.2.3",
    "inquirer": "^10.0.0"
  }
}
