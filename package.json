{
  "name": "sk-n2k-emitter",
  "version": "1.1.2",
  "description": "Signal K server plugin to convert Signal K to NMEA2000 with Garmin PGN specification alignment and canboatjs framework compatibility",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run clean && mkdir -p dist/sk-n2k-emitter && esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/sk-n2k-emitter/index.js --external:@canboat/canboatjs --external:rxjs --external:es-toolkit --external:path-scurry && cp package.json README.md LICENSE CHANGELOG.md dist/sk-n2k-emitter/",
    "build:npm": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --external:@canboat/canboatjs --external:rxjs --external:es-toolkit --external:path-scurry",
    "build:watch": "npm run build -- --watch",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "biome lint src/",
    "format": "biome format src/ --write",
    "check": "biome check src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build:npm",
    "create-release": "github-create-release --owner NearlCrews --repository sk-n2k-emitter",
    "release": "git tag -d v$npm_package_version ; git tag v$npm_package_version && git push --tags && git push && npm run create-release"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-nmea2000",
    "signalk-category-navigation",
    "nmea2000",
    "garmin",
    "marine-electronics",
    "ais",
    "navigation"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "appIcon": "./assets/icons/icon-72x72.png",
    "displayName": "SignalK to N2K Emitter"
  },
  "author": {
    "name": "Scott Bender",
    "email": "scott@scottbender.net"
  },
  "contributors": [
    {
      "name": "Teppo Kurki"
    },
    {
      "name": "NearlCrews",
      "url": "https://github.com/NearlCrews"
    }
  ],
  "license": "ISC",
  "dependencies": {
    "rxjs": "^7.8.2",
    "es-toolkit": "^1.28.1",
    "path-scurry": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NearlCrews/sk-n2k-emitter"
  },
  "devDependencies": {
    "@canboat/canboatjs": "^3.11.0",
    "@types/node": "^22.10.5",
    "@vitest/ui": "^3.2.4",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "signalk-server": "^2.16.0"
  },
  "engines": {
    "node": ">=20"
  }
}
